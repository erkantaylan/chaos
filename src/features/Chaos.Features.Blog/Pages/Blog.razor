@page "/blog"
@page "/"
@attribute [AllowAnonymous]
@layout Chaos.Layout.PublicLayout
@using Chaos.Application
@using Chaos.Domain
@using Microsoft.Extensions.Localization
@using Volo.Abp.Application.Dtos
@inject IBlogPostAppService BlogPostAppService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<BlogResource> L

@if (_loading)
{
    <p style="color: var(--neutral-foreground-hint);">@L["Loading"]</p>
}
else if (_posts.Count == 0)
{
    <p style="color: var(--neutral-foreground-hint);">@L["NoPublishedPosts"]</p>
}
else
{
    @foreach (var post in _posts)
    {
        <article class="post-item" @onclick="@(() => ViewPost(post.PostNumber, post.Slug))">
            <h2 class="post-title">@post.Title</h2>
            @if (post.PublishedAt.HasValue)
            {
                <time class="post-date">@post.PublishedAt.Value.ToString("MMMM dd, yyyy")</time>
            }
            @if (!string.IsNullOrEmpty(post.Summary))
            {
                <p class="post-summary">@post.Summary</p>
            }
        </article>
    }
}

<style>
    .post-item {
        padding: 24px 0;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
        cursor: pointer;
    }

    .post-item:last-child {
        border-bottom: none;
    }

    .post-item:hover .post-title {
        color: var(--accent-fill-rest);
    }

    .post-title {
        font-size: 1.35rem;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: var(--neutral-foreground-rest);
        transition: color 0.15s;
    }

    .post-date {
        font-size: 0.85rem;
        color: var(--neutral-foreground-hint);
        display: block;
        margin-bottom: 8px;
    }

    .post-summary {
        color: var(--neutral-foreground-hint);
        margin: 0;
        line-height: 1.5;
    }
</style>

@code {
    private List<BlogPostDto> _posts = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPostsAsync();
    }

    private async Task LoadPostsAsync()
    {
        _loading = true;
        try
        {
            var result = await BlogPostAppService.GetPublishedListAsync(new BlogPostGetListInput
            {
                MaxResultCount = 20,
                SkipCount = 0
            });
            _posts = result.Items.ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ViewPost(int postNumber, string slug)
    {
        NavigationManager.NavigateTo($"/blog/{postNumber}/{slug}");
    }
}
