@page "/blog/{PostNumber:int}/{Slug?}"
@attribute [AllowAnonymous]
@layout Chaos.Layout.PublicLayout
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Chaos.Application
@using Chaos.Domain
@using Microsoft.Extensions.Localization
@using Markdig
@inject IBlogPostAppService BlogPostAppService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<BlogResource> L

@if (_loading)
{
    <p style="color: var(--neutral-foreground-hint);">@L["Loading"]</p>
}
else if (_post == null)
{
    <p>@L["NoPosts"]</p>
    <a href="/blog">&larr; @L["BackToBlog"]</a>
}
else
{
    <a href="/blog" class="back-link">&larr; @L["BackToBlog"]</a>

    <article class="blog-article">
        <h1>@_post.Title</h1>

        @if (_post.PublishedAt.HasValue)
        {
            <time class="post-date">@_post.PublishedAt.Value.ToString("MMMM dd, yyyy")</time>
        }

        @if (!string.IsNullOrEmpty(_post.CoverImageUrl))
        {
            <div style="margin: 24px 0; border-radius: 8px; overflow: hidden;">
                <img src="@_post.CoverImageUrl" alt="@_post.Title" style="width: 100%; max-height: 400px; object-fit: cover;" />
            </div>
        }

        <div class="blog-content">
            @((MarkupString)_renderedContent)
        </div>
    </article>
}

<style>
    .back-link {
        display: inline-block;
        margin-bottom: 24px;
        color: var(--neutral-foreground-hint);
        text-decoration: none;
        font-size: 0.9rem;
    }

    .back-link:hover {
        color: var(--accent-fill-rest);
    }

    .blog-article h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 8px 0;
        line-height: 1.3;
    }

    .post-date {
        font-size: 0.85rem;
        color: var(--neutral-foreground-hint);
        display: block;
        margin-bottom: 24px;
    }

    .blog-content {
        line-height: 1.7;
        font-size: 1.05rem;
    }

    .blog-content h2 { font-size: 1.5rem; margin: 32px 0 12px; }
    .blog-content h3 { font-size: 1.25rem; margin: 24px 0 8px; }
    .blog-content p { margin: 0 0 16px; }
    .blog-content ul, .blog-content ol { margin: 0 0 16px; padding-left: 24px; }
    .blog-content pre {
        background: var(--neutral-layer-3);
        padding: 16px;
        border-radius: 6px;
        overflow-x: auto;
        margin: 0 0 16px;
        font-size: 0.9rem;
    }
    .blog-content code {
        font-family: 'Cascadia Code', 'Fira Code', monospace;
    }
    .blog-content :not(pre) > code {
        background: var(--neutral-layer-3);
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.9em;
    }
</style>

@code {
    [Parameter]
    public int PostNumber { get; set; }

    [Parameter]
    public string? Slug { get; set; }

    private BlogPostDto? _post;
    private string _renderedContent = string.Empty;
    private bool _loading = true;

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnInitializedAsync()
    {
        await LoadPostAsync();
    }

    private async Task LoadPostAsync()
    {
        _loading = true;
        try
        {
            _post = await BlogPostAppService.GetByPostNumberAsync(PostNumber);

            if (_post != null)
            {
                if (string.IsNullOrEmpty(Slug) || Slug != _post.Slug)
                {
                    NavigationManager.NavigateTo($"/blog/{PostNumber}/{_post.Slug}", replace: true);
                    return;
                }

                _renderedContent = Markdown.ToHtml(_post.Content, Pipeline);
            }
        }
        finally
        {
            _loading = false;
        }
    }
}
