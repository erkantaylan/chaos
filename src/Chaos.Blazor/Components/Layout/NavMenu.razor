@inherits Chaos.Blazor.ChaosComponentBase
@using Microsoft.FluentUI.AspNetCore.Components

<FluentNavLink Href="/dashboard" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.DataLine())">@L["Menu:Dashboard"]</FluentNavLink>
<FluentNavLink Href="/todos" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.TaskListSquareLtr())">@L["Menu:Todos"]</FluentNavLink>
<FluentNavLink Href="/chat" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.Chat())">@L["Menu:Chat"]</FluentNavLink>
<FluentNavLink Href="/shopping" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.ShoppingBag())">@L["Menu:Shopping"]</FluentNavLink>
<FluentNavLink Href="/blog/manage" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.DocumentEdit())">@L["Menu:BlogPosts"]</FluentNavLink>
<FluentNavGroup Title="@L["Menu:Administration"]" Icon="@(new Icons.Regular.Size20.ShieldTask())" Expanded="false">
    <FluentNavLink Href="/identity/users" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.People())">@L["Menu:Users"]</FluentNavLink>
    <FluentNavLink Href="/identity/roles" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.Shield())">@L["Menu:Roles"]</FluentNavLink>
</FluentNavGroup>
